   "source": [
    "# Simple Interest\n",
    "P = float(input(\"Enter Principal: \"))\n",
    "R = float(input(\"Enter Rate (%): \"))\n",
    "T = float(input(\"Enter Time (years): \"))\n",
    "\n",
    "A = P * (1 + (R/100) * T)\n",
    "\n",
    "print(\"Amount (Simple Interest) =\", A)"
   ]
